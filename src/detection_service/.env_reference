# ── Redis ────────────────────────────────────────────────────────
USE_REDIS=false                        # true = consume from Redis Stream, false = HTTP API mode
REDIS_HOST=localhost
REDIS_PORT=6379
CONSUMER_NAME=detector-1               # unique name within the consumer group

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR

# ── Anomaly Engine ───────────────────────────────────────────────
ANOMALY_WINDOW_SIZE=100                # max latency samples per service
ANOMALY_Z_THRESHOLD=2.5                # z-score threshold for outlier detection
ANOMALY_RATE_WINDOW_SECONDS=60         # sliding window for rate-based detectors
ANOMALY_RATE_THRESHOLD_MULTIPLIER=3.0  # frequency spike multiplier over baseline mean
ANOMALY_MIN_SAMPLES=10                 # minimum samples before anomaly detection activates

# ── Forwarding (API mode only) ───────────────────────────────────
FORWARD_URL=                           # optional URL to POST signals (e.g. incident management)

# ── Rulebook ─────────────────────────────────────────────────────
# RULEBOOK_PATH=./rulebook.json        # override path to rulebook (default: auto-detected)